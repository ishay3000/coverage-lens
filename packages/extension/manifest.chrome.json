{
  "manifest_version": 3,
  "name": "Coverage Lens",
  "version": "1.0.0",
  "description": "Line-by-line code coverage overlay on GitHub PR diff pages. Supports Cobertura XML.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "background-sw.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    },
    "default_popup": "popup.html",
    "default_title": "Coverage Lens Settings"
  }
}
