{
  "manifest_version": 2,
  "name": "Coverage Lens",
  "version": "1.0.0",
  "description": "Line-by-line code coverage overlay on GitHub PR diff pages. Supports Cobertura XML.",
  "browser_specific_settings": {
    "gecko": {
      "id": "coverage-lens@ishay3000",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "https://github.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "scripts": [
      "lib/jszip.min.js",
      "lib/cobertura-parser.js",
      "lib/coverage-loader.js",
      "lib/github-api.js",
      "lib/cache.js",
      "background.js"
    ]
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "browser_action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    },
    "default_popup": "popup.html",
    "default_title": "Coverage Lens Settings"
  }
}
