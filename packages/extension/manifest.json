{
  "manifest_version": 2,
  "name": "Coverage Lens",
  "version": "1.1.0",
  "description": "Line-by-line code coverage overlay on GitHub PR diff pages.",
  "browser_specific_settings": {
    "gecko": {
      "id": "coverage-lens@ishay3000",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "https://github.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "scripts": [
      "lib/vendor/jszip.min.js",
      "lib/parsers/json-coverage-parser.js",
      "lib/loaders/coverage-loader.js",
      "lib/api/github-api.js",
      "lib/api/cache.js",
      "background.js"
    ]
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "browser_action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    },
    "theme_icons": [
      {
        "light": "icons/toolbar-dark.svg",
        "dark": "icons/toolbar-light.svg",
        "size": 16
      },
      {
        "light": "icons/toolbar-dark.svg",
        "dark": "icons/toolbar-light.svg",
        "size": 32
      }
    ],
    "default_popup": "popup.html",
    "default_title": "Coverage Lens Settings"
  }
}
